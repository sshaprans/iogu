# 1. Використовуємо офіційний образ PHP 8.2 з уже встановленим Apache
FROM php:8.2-apache

# 2. Копіюємо вміст твоєї папки 'dist' у робочу директорію веб-сервера
COPY dist/ /var/www/html/

# 3. Вмикаємо модуль Apache 'mod_rewrite', який необхідний для роботи .htaccess
RUN a2enmod rewrite

# 4. Відкриваємо порт 80, щоб контейнер міг приймати запити
EXPOSE 80