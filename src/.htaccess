#RewriteCond %{HTTP_REFERER} !^https://test.iogu.gov.ua$      [NC]
RewriteCond %{HTTP_REFERER} !^https://www.iogu.gov.ua/.*$      [NC]
RewriteCond %{HTTP_REFERER} !^https://www.iogu.gov.ua$      [NC]
RewriteCond %{HTTP_REFERER} !^https://www.media.iogu.gov.ua/.*$      [NC]
RewriteCond %{HTTP_REFERER} !^https://www.media.iogu.gov.ua$      [NC]
