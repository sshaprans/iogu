#RewriteCond %{HTTP_REFERER} !^http://www.test.iogu.gov.ua$      [NC]
RewriteCond %{HTTP_REFERER} !^https://iogu.gov.ua/.*$      [NC]
RewriteCond %{HTTP_REFERER} !^https://iogu.gov.ua$      [NC]
RewriteCond %{HTTP_REFERER} !^https://media.iogu.gov.ua/.*$      [NC]
RewriteCond %{HTTP_REFERER} !^https://media.iogu.gov.ua$      [NC]
#RewriteCond %{HTTP_REFERER} !^https://old.iogu.gov.ua/.*$      [NC]
