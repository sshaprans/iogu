#RewriteCond %{HTTP_REFERER} !^http://test.iogu.gov.ua$      [NC]
RewriteCond %{HTTP_REFERER} !^http://www.iogu.gov.ua/.*$      [NC]
RewriteCond %{HTTP_REFERER} !^http://www.iogu.gov.ua$      [NC]
RewriteCond %{HTTP_REFERER} !^http://www.media.iogu.gov.ua/.*$      [NC]
RewriteCond %{HTTP_REFERER} !^http://www.media.iogu.gov.ua$      [NC]
