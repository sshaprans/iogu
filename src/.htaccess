# Google Search and other referrers you had
RewriteCond %{HTTP_REFERER} !^https://www.google.com/.*$ [NC]
RewriteRule .*\.(jpg|jpeg|gif|png|bmp)$ - [F,NC]

RewriteRule ^sitemap\.xml$ sitemap.php [L]